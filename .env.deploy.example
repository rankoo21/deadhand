# Copy this file to ".env.deploy" and add deployment credentials.
# ".env.deploy" is gitignored and must never be committed.
#
#   copy .env.deploy.example .env.deploy
#
# Private key of the funded account used only for explicit deploy or live scripts.
GENLAYER_PRIVATE_KEY=
# studionet (default) | bradbury | localnet
GENLAYER_NETWORK=bradbury
# Set after deployment for the explicit livecheck and fulltest scripts.
TESTLENS_CONTRACT_ADDRESS=
