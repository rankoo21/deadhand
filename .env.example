# Deadhand environment
# The chamber runs fully in mock mode with no configuration.
# To open against a deployed GenLayer contract, set the values below.

# "mock" (default) or "contract"
NEXT_PUBLIC_DEADHAND_MODE=mock

# Deployed DeadhandContract address (only used when mode is "contract")
NEXT_PUBLIC_DEADHAND_CONTRACT=

# studionet (default) | bradbury | localnet
NEXT_PUBLIC_DEADHAND_NETWORK=studionet
