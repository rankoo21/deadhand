# TestLens frontend environment
# Preview mode requires no wallet, contract, or network access.

# "preview" (default) or "contract"
NEXT_PUBLIC_TESTLENS_MODE=preview

# Deployed TestLensContract address, used only in contract mode
NEXT_PUBLIC_TESTLENS_CONTRACT=

# studionet (default) | bradbury | localnet
NEXT_PUBLIC_TESTLENS_NETWORK=studionet